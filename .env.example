# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# API key for the medical license data provider
LICENSE_API_KEY=your_api_key_here

# Base URL for the license data API (defaults to https://api.licensy.ai/v2 if not set)
LICENSE_API_BASE_URL=https://api.licensy.ai/v2

# Public base URL for this site (used in sitemap, canonical URLs, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.medicallicensesearch.com

# Simple IP rate-limit: max requests per window per IP (default: 20)
RATE_LIMIT_MAX=20

# Rate-limit window in seconds (default: 60)
RATE_LIMIT_WINDOW_SECONDS=60
